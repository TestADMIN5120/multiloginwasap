# scripts/deploy/eas.json
# ---------------------------------------------------------------------------
# EAS Build profile config for the Expo mobile app.
#
# Workflow:
#   cd mobile
#   npm install -g eas-cli         # one time
#   eas login                       # one time (free Expo account)
#   eas init                        # links project, generates a project ID
#   eas build --profile preview --platform android
#       -> EAS Cloud builds an APK in ~10-15 min.
#          When done you get a URL/QR — install on your phone.
#
#   For release-grade builds use --profile production (signed for stores).
# ---------------------------------------------------------------------------
{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "API_URL":     "https://multiptabwatsap-api.onrender.com",
        "SOCKET_URL":  "https://multiptabwatsap-api.onrender.com",
        "DEV_SKIP_OTP": "true"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "API_URL":     "https://multiptabwatsap-api.onrender.com",
        "SOCKET_URL":  "https://multiptabwatsap-api.onrender.com",
        "DEV_SKIP_OTP": "true"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "API_URL":     "https://multiptabwatsap-api.onrender.com",
        "SOCKET_URL":  "https://multiptabwatsap-api.onrender.com",
        "DEV_SKIP_OTP": "false"
      }
    }
  },
  "submit": {
    "production": {}
  }
}

