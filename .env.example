# Copy this file to `.env` and edit before running `docker compose up`.
# Compose substitutes ${VAR} in docker-compose.yml from this file automatically.

# A long random string. Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=please-change-me-to-a-long-random-string

# In dev / first run leave true so the OTP code is returned in the API response.
# Switch to false once you wire a real SMS provider.
OTP_DEV_RETURN=true

# DEV ONLY: when "true" the API exposes POST /api/auth/dev-login that issues a
# phone session token from just a phone number — no OTP roundtrip at all.
# Set to "false" in any environment that's reachable from the public internet.
OTP_DEV_BYPASS=false

# Comma-separated origins that are allowed to call the API. Use "*" only for early dev.
CORS_ORIGIN=*

# Public host:port the API will be reachable on (only used by the optional reverse-proxy profile).
PUBLIC_HOST=localhost

