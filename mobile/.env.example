// mobile/.env.example — copy to .env and edit
# IMPORTANT: when running Expo on a physical phone, this MUST be your dev machine's
# LAN IP, NOT localhost. e.g. http://192.168.1.10:4000
API_URL=http://192.168.1.10:4000
SOCKET_URL=http://192.168.1.10:4000

# DEV ONLY: skip the OTP screen entirely — phone number is enough to log in.
# Backend must also have OTP_DEV_BYPASS=true (see repo-root .env).
DEV_SKIP_OTP=false

