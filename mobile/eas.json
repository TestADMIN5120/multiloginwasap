{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "API_URL": "http://192.168.1.12:4000",
        "SOCKET_URL": "http://192.168.1.12:4000",
        "DEV_SKIP_OTP": "true"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "API_URL": "http://192.168.1.12:4000",
        "SOCKET_URL": "http://192.168.1.12:4000",
        "DEV_SKIP_OTP": "true"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "API_URL": "https://REPLACE-WITH-YOUR-PUBLIC-DOMAIN.example.com",
        "SOCKET_URL": "https://REPLACE-WITH-YOUR-PUBLIC-DOMAIN.example.com",
        "DEV_SKIP_OTP": "false"
      }
    }
  },
  "submit": {
    "production": {}
  }
}

