# Server
NODE_ENV=development
PORT=4000
CORS_ORIGIN=*

# Mongo
MONGO_URI=mongodb://localhost:27017/multiptabwatsap

# JWT
JWT_SECRET=replace-with-a-long-random-string
JWT_PHONE_TTL=30m
JWT_ACCOUNT_TTL=30d

# OTP
OTP_TTL_SECONDS=300
OTP_LENGTH=6
# In dev, return the OTP code in the API response (skip SMS)
OTP_DEV_RETURN=true

# Uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=15

